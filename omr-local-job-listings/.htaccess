# Optional: clean URLs for job detail (/job/15 or /job/15/slug → job-detail-omr.php?id=15).
# Root .htaccess handles the primary rewrite; this supports optional slug for consistency.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /omr-local-job-listings/
RewriteRule ^job/([0-9]+)(?:/([a-z0-9-]+))?/?$ job-detail-omr.php?id=$1 [L,QSA]
</IfModule>
